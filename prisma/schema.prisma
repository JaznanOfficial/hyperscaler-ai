generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  displayId   String?  @unique
  name        String
  email       String   @unique
  phone       String?
  password    String
  role        UserRole @default(CLIENT)
  projects    Json     @default("[]")
  generalInfo Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  subscriptionId String             @unique
  priceId        String
  invoiceId      String?
  packageName    String?
  amount         Int
  status         SubscriptionStatus @default(UNPAID)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Project {
  id                String        @id @default(cuid())
  clientId          String
  assignedEmployees Json          @default("[]")
  services          Json          @default("[]")
  status            ProjectStatus @default(PENDING)
  read              Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  serviceName String
  sections    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slug        String?  @unique
}

model Feedback {
  id         String   @id @default(cuid())
  projectId  String
  employeeId String
  heading    String
  details    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MetricHistory {
  id          String   @id @default(cuid())
  projectId   String
  serviceId   String
  serviceName String
  metrics     Json     @default("{}")
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([projectId, serviceId, recordedAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  userId    String
  createdAt DateTime @default(now())
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
  CLIENT
}

enum SubscriptionStatus {
  PAID
  UNPAID
  CANCELLED
}

enum ProjectStatus {
  APPROVED
  PENDING
  CANCELLED
}
