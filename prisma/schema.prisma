generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  displayId   String?  @unique
  name        String
  email       String   @unique
  phone       String?
  password    String
  role        UserRole @default(CLIENT)
  getStarted  Boolean  @default(false) @map("get_started")
  projects    Json     @default("[]")
  generalInfo Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  subscriptionId String             @unique
  priceId        String
  invoiceId      String?
  packageName    String?
  amount         Int
  status         SubscriptionStatus @default(UNPAID)
  nextBillingAt  DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model ClientService {
  id                String        @id @default(cuid())
  clientId          String
  assignedEmployees Json          @default("[]")
  services          String        @default("")
  status            ClientServiceStatus @default(PENDING)
  read              Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Feedback {
  id         String   @id @default(cuid())
  projectId  String
  employeeId String
  heading    String
  details    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MetricHistory {
  id        String   @id @default(cuid())
  clientId  String
  serviceId String
  history   Json     @default("[]")
  entryDate DateTime @default(now())

  @@index([clientId, serviceId, entryDate])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  userId    String
  createdAt DateTime @default(now())
}

model OnboardingProfile {
  id                  String   @id @default(cuid())
  userId              String?  @unique
  email               String?  @unique
  businessName        String
  industry            String
  businessStage       String
  websiteUrl          String?
  monthlyRevenueRange String?
  services            Json     @default("[]")
  discoverySource     String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model NonLoggedOnboardingProfile {
  id                  String   @id @default(cuid())
  name                String
  phone               String
  businessName        String
  industry            String
  businessStage       String
  websiteUrl          String?
  monthlyRevenueRange String?
  services            Json     @default("[]")
  discoverySource     String   @default("unknown")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
  CLIENT
}

enum SubscriptionStatus {
  PAID
  UNPAID
  CANCELLED
}

enum ClientServiceStatus {
  APPROVED
  PENDING
  CANCELLED
}
